# Build artifacts — regenerated by the Docker build process
node_modules/
dist/

# Version control — not needed in the image
.git/
.github/

# Logs
*.log

# Environment files — NEVER bake secrets into an image
.env
.env.*

# macOS metadata files
.DS_Store

# Documentation — reduces image context size
docs/
*.md

# Editor and IDE configs
.vscode/
.idea/
*.swp
*.swo

# Test and coverage outputs
coverage/
.nyc_output/
